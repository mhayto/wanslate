# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=your_meta_permanent_access_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id_here

# Webhook verification — set to any secret string, enter the same value in Meta dashboard
VERIFY_TOKEN=your_secret_verify_token_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
